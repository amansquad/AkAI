<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/akai_accent" />
            <corners android:radius="12dp" />
            <size
                android:width="48dp"
                android:height="48dp" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/akai_key_background" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="@color/akai_accent" />
            <size
                android:width="48dp"
                android:height="48dp" />
        </shape>
    </item>
</selector>
