<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/app_background</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>

    <!-- Keyboard Theme -->
    <style name="KeyboardTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/akai_background</item>
        <item name="android:statusBarColor">@color/akai_background</item>
        <item name="android:navigationBarColor">@color/akai_background</item>
        <item name="colorPrimary">@color/akai_accent</item>
        <item name="colorPrimaryDark">@color/akai_special_key</item>
        <item name="colorAccent">@color/akai_accent</item>
    </style>

    <!-- Settings Theme -->
    <style name="SettingsTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- Button Styles -->
    <style name="AkaiButton" parent="Widget.AppCompat.Button.Colored">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:backgroundTint">@color/button_primary</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Switch Styles -->
    <style name="AkaiSwitch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="thumbTint">@color/akai_accent</item>
        <item name="trackTint">@color/akai_key_background</item>
    </style>

    <!-- Text Styles -->
    <style name="AkaiTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AkaiSubtitle">
        <item name="android:textColor">@color/akai_accent</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AkaiBody">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="AkaiCaption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
